{
  "openapi": "3.1.0",
  "info": {
    "title": "TravelContext API",
    "summary": "API for the intelligent travel planning DSS prototype.",
    "description": "TravelContext API powers a prototype decision support system for personalized travel planning. The current API version exposes health checks, cities, points of interest, trip requests, and personalized recommendations from seed data. It will be extended with route planning, feedback, and persistent storage.",
    "contact": {
      "name": "TravelContext project"
    },
    "license": {
      "name": "Academic prototype"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8000",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "health"
        ],
        "summary": "Check API health",
        "description": "Returns the current backend service status. This endpoint is used for local checks, deployment checks, and screenshots.",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "The backend API is available.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                },
                "example": {
                  "status": "ok"
                }
              }
            }
          }
        }
      }
    },
    "/cities": {
      "get": {
        "tags": [
          "cities"
        ],
        "summary": "List available cities",
        "description": "Returns cities available in the current MVP seed dataset. Each city includes the number of available points of interest.",
        "operationId": "get_cities_cities_get",
        "responses": {
          "200": {
            "description": "Available cities.",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/CityResponse"
                  },
                  "type": "array",
                  "title": "Response Get Cities Cities Get"
                }
              }
            }
          }
        }
      }
    },
    "/cities/{city_id}": {
      "get": {
        "tags": [
          "cities"
        ],
        "summary": "Get city by id",
        "description": "Returns one city from the current MVP seed dataset.",
        "operationId": "get_city_by_id_cities__city_id__get",
        "parameters": [
          {
            "name": "city_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "City Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "City details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CityResponse"
                }
              }
            }
          },
          "404": {
            "description": "City was not found.",
            "content": {
              "application/json": {
                "example": {
                  "detail": "City not found"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/cities/{city_id}/pois": {
      "get": {
        "tags": [
          "cities"
        ],
        "summary": "List city points of interest",
        "description": "Returns points of interest for a city. Results can be filtered by normalized category and paginated with limit/offset.",
        "operationId": "get_city_points_of_interest_cities__city_id__pois_get",
        "parameters": [
          {
            "name": "city_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "City Id"
            }
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional normalized category filter.",
              "examples": [
                "history"
              ],
              "title": "Category"
            },
            "description": "Optional normalized category filter."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Maximum number of POI records to return.",
              "default": 50,
              "title": "Limit"
            },
            "description": "Maximum number of POI records to return."
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of POI records to skip.",
              "default": 0,
              "title": "Offset"
            },
            "description": "Number of POI records to skip."
          }
        ],
        "responses": {
          "200": {
            "description": "City points of interest.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PointOfInterestResponse"
                  },
                  "title": "Response Get City Points Of Interest Cities  City Id  Pois Get"
                }
              }
            }
          },
          "404": {
            "description": "City was not found.",
            "content": {
              "application/json": {
                "example": {
                  "detail": "City not found"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pois/{poi_id}": {
      "get": {
        "tags": [
          "points-of-interest"
        ],
        "summary": "Get point of interest by id",
        "description": "Returns one point of interest from the current MVP seed dataset.",
        "operationId": "get_point_of_interest_by_id_pois__poi_id__get",
        "parameters": [
          {
            "name": "poi_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Poi Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Point of interest details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PointOfInterestResponse"
                }
              }
            }
          },
          "404": {
            "description": "Point of interest was not found.",
            "content": {
              "application/json": {
                "example": {
                  "detail": "Point of interest not found"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/trip-requests": {
      "post": {
        "tags": [
          "planning"
        ],
        "summary": "Create trip planning request",
        "description": "Creates an in-memory trip planning request from city, user profile, trip duration, and resource constraints. The generated id can be used to request recommendations.",
        "operationId": "create_trip_request_endpoint_trip_requests_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TripRequestCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created trip request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TripRequestResponse"
                }
              }
            }
          },
          "404": {
            "description": "City was not found.",
            "content": {
              "application/json": {
                "example": {
                  "detail": "City not found"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/recommendations/generate": {
      "post": {
        "tags": [
          "planning"
        ],
        "summary": "Generate personalized recommendations",
        "description": "Generates a ranked list of points of interest for an existing trip request. The scoring model combines interest match, budget fit, route convenience, pace fit, popularity, and data quality.",
        "operationId": "generate_recommendations_endpoint_recommendations_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecommendationGenerateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Ranked recommendations with explanations.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecommendationListResponse"
                }
              }
            }
          },
          "404": {
            "description": "Trip request or city was not found.",
            "content": {
              "application/json": {
                "examples": {
                  "tripNotFound": {
                    "summary": "Trip request not found",
                    "value": {
                      "detail": "Trip request not found"
                    }
                  },
                  "cityNotFound": {
                    "summary": "City not found",
                    "value": {
                      "detail": "City not found"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CityResponse": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id",
            "description": "Internal city identifier.",
            "examples": [
              3
            ]
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "City name.",
            "examples": [
              "Казань"
            ]
          },
          "region": {
            "type": "string",
            "title": "Region",
            "description": "Russian region name.",
            "examples": [
              "Республика Татарстан"
            ]
          },
          "country": {
            "type": "string",
            "title": "Country",
            "description": "Country name.",
            "examples": [
              "Россия"
            ]
          },
          "latitude": {
            "type": "number",
            "title": "Latitude",
            "description": "City center latitude.",
            "examples": [
              55.7961
            ]
          },
          "longitude": {
            "type": "number",
            "title": "Longitude",
            "description": "City center longitude.",
            "examples": [
              49.1064
            ]
          },
          "population": {
            "type": "integer",
            "title": "Population",
            "description": "Approximate city population.",
            "examples": [
              1300000
            ]
          },
          "source": {
            "type": "string",
            "title": "Source",
            "description": "Data source identifier.",
            "examples": [
              "manual_seed"
            ]
          },
          "external_id": {
            "type": "string",
            "title": "External Id",
            "description": "Stable source-specific city identifier.",
            "examples": [
              "kazan"
            ]
          },
          "wikidata_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Wikidata Id",
            "description": "Linked Wikidata Q-id if available.",
            "examples": [
              "Q900"
            ]
          },
          "osm_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Osm Id",
            "description": "Linked OpenStreetMap object id if available.",
            "examples": [
              123456
            ]
          },
          "pois_count": {
            "type": "integer",
            "title": "Pois Count",
            "description": "Number of points of interest currently available for the city.",
            "examples": [
              8
            ]
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "region",
          "country",
          "latitude",
          "longitude",
          "population",
          "source",
          "external_id",
          "pois_count"
        ],
        "title": "CityResponse"
      },
      "ConstraintStatus": {
        "properties": {
          "budget": {
            "type": "string",
            "title": "Budget",
            "description": "Budget constraint status.",
            "examples": [
              "within_budget"
            ]
          },
          "pace": {
            "type": "string",
            "title": "Pace",
            "description": "Pace constraint status.",
            "examples": [
              "fits_moderate_pace"
            ]
          },
          "distance": {
            "type": "string",
            "title": "Distance",
            "description": "Distance constraint status.",
            "examples": [
              "near_city_center"
            ]
          }
        },
        "type": "object",
        "required": [
          "budget",
          "pace",
          "distance"
        ],
        "title": "ConstraintStatus"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Current backend service status.",
            "examples": [
              "ok"
            ]
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse"
      },
      "PointOfInterestResponse": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id",
            "description": "Internal point of interest identifier.",
            "examples": [
              3001
            ]
          },
          "city_id": {
            "type": "integer",
            "title": "City Id",
            "description": "Internal city identifier.",
            "examples": [
              3
            ]
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Point of interest name.",
            "examples": [
              "Казанский кремль"
            ]
          },
          "category": {
            "type": "string",
            "title": "Category",
            "description": "Normalized internal category.",
            "examples": [
              "history"
            ]
          },
          "subcategory": {
            "type": "string",
            "title": "Subcategory",
            "description": "More specific internal subcategory.",
            "examples": [
              "museum_complex"
            ]
          },
          "latitude": {
            "type": "number",
            "title": "Latitude",
            "description": "POI latitude.",
            "examples": [
              55.7996
            ]
          },
          "longitude": {
            "type": "number",
            "title": "Longitude",
            "description": "POI longitude.",
            "examples": [
              49.1055
            ]
          },
          "address": {
            "type": "string",
            "title": "Address",
            "description": "Human-readable address.",
            "examples": [
              "Кремль"
            ]
          },
          "description": {
            "type": "string",
            "title": "Description",
            "description": "Short POI description."
          },
          "opening_hours": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Opening Hours",
            "description": "Opening hours in source format if available.",
            "examples": [
              "10:00-18:00"
            ]
          },
          "website": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Website",
            "description": "Official or reference website if available.",
            "examples": [
              "https://kazan-kremlin.ru"
            ]
          },
          "phone": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Phone",
            "description": "Contact phone if available.",
            "examples": [
              "+7 (843) 292-70-70"
            ]
          },
          "source": {
            "type": "string",
            "title": "Source",
            "description": "Data source identifier.",
            "examples": [
              "manual_seed"
            ]
          },
          "external_id": {
            "type": "string",
            "title": "External Id",
            "description": "Stable source-specific POI identifier.",
            "examples": [
              "kazan-kremlin"
            ]
          },
          "wikidata_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Wikidata Id",
            "description": "Linked Wikidata Q-id if available.",
            "examples": [
              "Q171223"
            ]
          },
          "osm_tags": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Osm Tags",
            "description": "Source-like OSM tags used for category mapping.",
            "examples": [
              {
                "tourism": "museum"
              }
            ]
          },
          "estimated_price_level": {
            "type": "string",
            "title": "Estimated Price Level",
            "description": "Estimated price level for planning constraints.",
            "examples": [
              "medium"
            ]
          },
          "average_cost_rub": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Average Cost Rub",
            "description": "Approximate expected cost in Russian rubles.",
            "examples": [
              1200
            ]
          },
          "estimated_visit_minutes": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Estimated Visit Minutes",
            "description": "Approximate visit duration in minutes.",
            "examples": [
              90
            ]
          },
          "popularity_score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Popularity Score",
            "description": "Normalized popularity estimate from 0 to 1.",
            "examples": [
              0.92
            ]
          },
          "data_quality_score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Data Quality Score",
            "description": "Normalized confidence/data quality estimate from 0 to 1.",
            "examples": [
              0.86
            ]
          },
          "interests": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Interests",
            "description": "Interest tags used by the recommendation engine.",
            "examples": [
              [
                "history",
                "architecture",
                "culture"
              ]
            ]
          }
        },
        "type": "object",
        "required": [
          "id",
          "city_id",
          "name",
          "category",
          "subcategory",
          "latitude",
          "longitude",
          "address",
          "description",
          "source",
          "external_id",
          "osm_tags",
          "estimated_price_level",
          "average_cost_rub",
          "estimated_visit_minutes",
          "popularity_score",
          "data_quality_score",
          "interests"
        ],
        "title": "PointOfInterestResponse"
      },
      "RecommendationFactors": {
        "properties": {
          "interest_match": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Interest Match",
            "description": "Interest match factor."
          },
          "budget_match": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Budget Match",
            "description": "Budget fit factor."
          },
          "route_convenience": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Route Convenience",
            "description": "Distance and route convenience factor."
          },
          "pace_match": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Pace Match",
            "description": "Pace fit factor."
          },
          "popularity_score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Popularity Score",
            "description": "POI popularity factor."
          },
          "data_quality_score": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Data Quality Score",
            "description": "POI data quality factor."
          }
        },
        "type": "object",
        "required": [
          "interest_match",
          "budget_match",
          "route_convenience",
          "pace_match",
          "popularity_score",
          "data_quality_score"
        ],
        "title": "RecommendationFactors"
      },
      "RecommendationGenerateRequest": {
        "properties": {
          "trip_request_id": {
            "type": "integer",
            "title": "Trip Request Id",
            "description": "Previously created trip request id.",
            "examples": [
              1
            ]
          },
          "limit": {
            "type": "integer",
            "maximum": 50.0,
            "minimum": 1.0,
            "title": "Limit",
            "description": "Maximum number of recommendations to return.",
            "default": 10,
            "examples": [
              8
            ]
          },
          "include_accommodation": {
            "type": "boolean",
            "title": "Include Accommodation",
            "description": "Whether accommodation objects should be included in recommendations.",
            "default": false,
            "examples": [
              false
            ]
          },
          "include_categories": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Include Categories",
            "description": "Optional category allow-list.",
            "examples": [
              [
                "history",
                "culture",
                "food",
                "nature"
              ]
            ]
          },
          "exclude_categories": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Exclude Categories",
            "description": "Optional category deny-list.",
            "examples": [
              [
                "shopping"
              ]
            ]
          }
        },
        "type": "object",
        "required": [
          "trip_request_id"
        ],
        "title": "RecommendationGenerateRequest"
      },
      "RecommendationListResponse": {
        "properties": {
          "trip_request_id": {
            "type": "integer",
            "title": "Trip Request Id",
            "description": "Trip request id.",
            "examples": [
              1
            ]
          },
          "city_id": {
            "type": "integer",
            "title": "City Id",
            "description": "City id.",
            "examples": [
              6
            ]
          },
          "total_candidates": {
            "type": "integer",
            "title": "Total Candidates",
            "description": "Number of candidate POIs before limiting.",
            "examples": [
              7
            ]
          },
          "recommendations": {
            "items": {
              "$ref": "#/components/schemas/RecommendationResponse"
            },
            "type": "array",
            "title": "Recommendations"
          }
        },
        "type": "object",
        "required": [
          "trip_request_id",
          "city_id",
          "total_candidates",
          "recommendations"
        ],
        "title": "RecommendationListResponse"
      },
      "RecommendationResponse": {
        "properties": {
          "poi_id": {
            "type": "integer",
            "title": "Poi Id",
            "description": "Recommended POI id.",
            "examples": [
              6005
            ]
          },
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Recommended POI name.",
            "examples": [
              "Золотой колос"
            ]
          },
          "category": {
            "type": "string",
            "title": "Category",
            "description": "Recommended POI category.",
            "examples": [
              "food"
            ]
          },
          "score": {
            "type": "number",
            "maximum": 1.0,
